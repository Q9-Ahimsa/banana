{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["bin/**/*.mjs", "lib/**/*.mjs", "adapters/**/*.mjs", "test/**/*.mjs"]
}
